---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="glass-card p-8 hover:scale-105 transition-transform duration-300">
  <img src={icon} alt={title} class="w-16 h-16 mb-4" />
  <h2 class="text-2xl font-bold mb-4 text-primary">{title}</h2>
  <p class="text-gray-600">{description}</p>
</div>