---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Achievements">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold mb-8 text-primary">Our Achievements</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="glass-card p-8">
        <h2 class="text-2xl font-bold mb-4 text-primary">Industry Recognition</h2>
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-primary font-bold mr-2">2023:</span>
            Best Technology Innovation Award
          </li>
          <li class="flex items-start">
            <span class="text-primary font-bold mr-2">2022:</span>
            Global Technology Leadership Award
          </li>
          <li class="flex items-start">
            <span class="text-primary font-bold mr-2">2021:</span>
            Excellence in Digital Transformation
          </li>
        </ul>
      </div>

      <div class="glass-card p-8">
        <h2 class="text-2xl font-bold mb-4 text-primary">Key Milestones</h2>
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-primary font-bold mr-2">2023:</span>
            Expanded to 50+ countries
          </li>
          <li class="flex items-start">
            <span class="text-primary font-bold mr-2">2022:</span>
            Reached 1000+ enterprise clients
          </li>
          <li class="flex items-start">
            <span class="text-primary font-bold mr-2">2021:</span>
            Launched revolutionary AI platform
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold mb-6 text-primary">Success Metrics</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="glass-card p-8 text-center">
          <div class="text-4xl font-bold mb-2 text-primary">500+</div>
          <div>Projects Completed</div>
        </div>
        <div class="glass-card p-8 text-center">
          <div class="text-4xl font-bold mb-2 text-primary">98%</div>
          <div>Client Satisfaction</div>
        </div>
        <div class="glass-card p-8 text-center">
          <div class="text-4xl font-bold mb-2 text-primary">50+</div>
          <div>Countries Served</div>
        </div>
        <div class="glass-card p-8 text-center">
          <div class="text-4xl font-bold mb-2 text-primary">1000+</div>
          <div>Team Members</div>
        </div>
      </div>
    </div>
  </div>
</Layout>