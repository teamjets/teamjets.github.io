---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "Smart City Integration",
    description: "Implementing IoT solutions for smart city management and monitoring.",
    image: "https://images.unsplash.com/photo-1573804633927-bfcbcd909acd?q=80&w=2027&auto=format&fit=crop",
    tags: ["IoT", "Smart City", "Infrastructure"]
  },
  {
    title: "AI-Powered Analytics",
    description: "Advanced analytics platform using artificial intelligence.",
    image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2070&auto=format&fit=crop",
    tags: ["AI", "Analytics", "Big Data"]
  },
  {
    title: "Cloud Migration",
    description: "Enterprise-scale cloud migration and optimization.",
    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop",
    tags: ["Cloud", "Migration", "Enterprise"]
  }
];

const caseStudies = [
  {
    title: "Global Retail Chain Transformation",
    description: "Helped a major retail chain digitize their operations across 1000+ stores.",
    image: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=2070&auto=format&fit=crop",
    tags: ["Digital Transformation", "Retail", "IoT"]
  },
  {
    title: "Healthcare AI Implementation",
    description: "Developed AI-powered diagnostic tools for a leading healthcare provider.",
    image: "https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?q=80&w=2070&auto=format&fit=crop",
    tags: ["Healthcare", "AI", "Machine Learning"]
  }
];
---

<Layout title="Projects">
  <div class="relative mb-16">
    <img 
      src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop"
      alt="Projects Header"
      class="w-full h-[400px] object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-secondary/80"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <h1 class="text-4xl font-bold text-white">Our Projects</h1>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map(project => (
        <div class="glass-card overflow-hidden">
          <img src={project.image} alt={project.title} class="w-full h-48 object-cover"/>
          <div class="p-8">
            <h3 class="text-xl font-bold mb-2 text-primary">{project.title}</h3>
            <p class="text-gray-600 mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="bg-primary/10 text-primary px-4 py-1 rounded-full text-sm">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16">
      <h2 class="text-3xl font-bold text-primary mb-8">Featured Case Studies</h2>
      <div class="space-y-8">
        {caseStudies.map(study => (
          <div class="glass-card overflow-hidden">
            <div class="grid grid-cols-1 md:grid-cols-2">
              <img src={study.image} alt={study.title} class="w-full h-full object-cover"/>
              <div class="p-8">
                <h3 class="text-xl font-bold mb-4 text-primary">{study.title}</h3>
                <p class="text-gray-600 mb-4">{study.description}</p>
                <div class="flex flex-wrap gap-2">
                  {study.tags.map(tag => (
                    <span class="bg-primary/10 text-primary px-4 py-1 rounded-full text-sm">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>