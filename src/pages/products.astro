---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    title: "JETS Analytics",
    description: "Advanced analytics platform with real-time insights and predictive modeling.",
    image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2070&auto=format&fit=crop",
    features: [
      "Real-time data processing",
      "AI-powered insights",
      "Custom reporting"
    ]
  },
  {
    title: "JETS Cloud",
    description: "Secure and scalable cloud infrastructure solutions for enterprises.",
    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop",
    features: [
      "High availability",
      "Automatic scaling",
      "24/7 support"
    ]
  },
  {
    title: "JETS Security",
    description: "Comprehensive cybersecurity solutions for modern businesses.",
    image: "https://images.unsplash.com/photo-1563986768609-322da13575f3?q=80&w=2070&auto=format&fit=crop",
    features: [
      "Threat detection",
      "Data encryption",
      "Compliance management"
    ]
  }
];
---

<Layout title="Products">
  <div class="relative mb-16">
    <img 
      src="https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2070&auto=format&fit=crop"
      alt="Products Header"
      class="w-full h-[400px] object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-secondary/80"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <h1 class="text-4xl font-bold text-white">Our Products</h1>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map(product => (
        <div class="glass-card overflow-hidden">
          <img src={product.image} alt={product.title} class="w-full h-48 object-cover"/>
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-4 text-primary">{product.title}</h2>
            <p class="text-gray-600 mb-4">{product.description}</p>
            <ul class="mb-6 space-y-2">
              {product.features.map(feature => (
                <li class="flex items-center">
                  <span class="text-green-500 mr-2">✓</span>
                  {feature}
                </li>
              ))}
            </ul>
            <a href="#" class="inline-block bg-primary/90 text-white px-6 py-2 rounded-full hover:bg-primary transition-colors">
              Learn More
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16">
      <h2 class="text-2xl font-bold mb-6 text-primary">Product Comparison</h2>
      <div class="overflow-x-auto glass-card p-0">
        <table class="w-full">
          <thead class="bg-primary/90 text-white">
            <tr>
              <th class="px-6 py-3 text-left rounded-tl-[50px]">Features</th>
              <th class="px-6 py-3 text-center">Basic</th>
              <th class="px-6 py-3 text-center">Pro</th>
              <th class="px-6 py-3 text-center rounded-tr-[50px]">Enterprise</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-white/10">
              <td class="px-6 py-4">24/7 Support</td>
              <td class="px-6 py-4 text-center">✓</td>
              <td class="px-6 py-4 text-center">✓</td>
              <td class="px-6 py-4 text-center">✓</td>
            </tr>
            <tr class="border-b border-white/10">
              <td class="px-6 py-4">Custom Analytics</td>
              <td class="px-6 py-4 text-center">-</td>
              <td class="px-6 py-4 text-center">✓</td>
              <td class="px-6 py-4 text-center">✓</td>
            </tr>
            <tr>
              <td class="px-6 py-4 rounded-bl-[50px]">API Access</td>
              <td class="px-6 py-4 text-center">-</td>
              <td class="px-6 py-4 text-center">-</td>
              <td class="px-6 py-4 text-center rounded-br-[50px]">✓</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>